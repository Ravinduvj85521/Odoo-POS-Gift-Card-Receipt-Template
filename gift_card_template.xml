<t t-name="loyalty.gift_card_report">
    <t t-call="web.html_container">
        <t t-call="web.basic_layout">

            <div style="width: 260px; margin: auto; font-family: monospace; text-align: center; color: #000; padding: 10px;">

                <!-- LOGO ONLY - no hardcoded brand text -->
                <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" style="max-height: 120px; margin-bottom: 4px;"/>

                <!-- ADDRESS -->
                <p style="margin: 8px 0 0; font-size: 16px;">
                   Add Address here
                </p>

                <hr style="border: none; border-top: 1px dashed #000; margin: 8px 0;"/>

                <p style="margin: 4px 0; font-size: 14px; font-weight: bold; letter-spacing: 3px;">GIFT CARD</p>

                <!-- AMOUNT -->
                <p style="margin: 6px 0; font-size: 22px; font-weight: bold;">
                    <span t-out="o.points" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                </p>

                <!-- CODE -->
                <p style="margin: 4px 0; font-size: 12px; letter-spacing: 2px;">
                    <span t-field="o.code"/>
                </p>

                <!-- BARCODE as QR — universally scannable -->
                <div style="margin: 10px auto;">
                    <img t-att-src="'/report/barcode/QR/'+o.code" style="width:200px; height:200px;" alt="QR Code"/>
                </div>

                <hr style="border: none; border-top: 1px dashed #000; margin: 8px 0;"/>

                <p style="margin: 2px 0; font-size: 14px;">Keep this receipt</p>
                <p style="margin: 2px 0; font-size: 14px;">In-store use only</p>

            </div>

        </t>
    </t>
</t>
